{
  "redirects": [
    {
      "source": "/",
      "destination": "https://zey-win.github.io",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/artifacts",
      "destination": "/api/artifacts.js"
    },
    {
      "source": "/api/build",
      "destination": "/api/build.js"
    },
    {
      "source": "/api/cancel",
      "destination": "/api/manage.js"
    },
    {
      "source": "/api/configs",
      "destination": "/api/configs.js"
    },
    {
      "source": "/api/delete",
      "destination": "/api/manage.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/api/branches",
      "destination": "/api/game.js"
    },
    {
      "source": "/api/generate-icon",
      "destination": "/api/generate-icon.js"
    },
    {
      "source": "/api/icon",
      "destination": "/api/icon.js"
    },
    {
      "source": "/api/logs",
      "destination": "/api/logs.js"
    },
    {
      "source": "/api/repos",
      "destination": "/api/game.js"
    },
    {
      "source": "/api/runs",
      "destination": "/api/runs.js"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  }
}
